{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "required": [
    "platform",
    "agent",
    "kmsType"
  ],
  "properties": {
    "nameOverride": {
      "type": "string",
      "default": "",
      "description": "Override the chart name used in resource names"
    },
    "fullnameOverride": {
      "type": "string",
      "default": "",
      "description": "Fully override the generated resource names"
    },
    "kmsType": {
      "type": "string",
      "description": "Key Management Service for storing internal Entitle secrets",
      "enum": [
        "kubernetes_secret_manager",
        "aws_secret_manager",
        "gcp_secret_manager",
        "azure_secret_manager",
        "hashicorp_vault"
      ]
    },
    "imageCredentials": {
      "type": "string",
      "default": "",
      "description": "Base64-encoded dockerconfigjson for the agent image registry. Optional — auto-extracted from agent.token if not set."
    },
    "imagePullSecret": {
      "type": "object",
      "description": "Reference a pre-existing image pull Secret",
      "properties": {
        "name": {
          "type": "string",
          "default": "",
          "description": "Name of an existing kubernetes.io/dockerconfigjson Secret"
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "description": "ServiceAccount configuration",
      "properties": {
        "create": {
          "type": "boolean",
          "default": true,
          "description": "Whether to create a ServiceAccount"
        },
        "name": {
          "type": "string",
          "default": "",
          "description": "Override the ServiceAccount name"
        },
        "annotations": {
          "type": "object",
          "description": "Additional annotations for the ServiceAccount"
        }
      }
    },
    "externalKmsParams": {
      "type": "object",
      "properties": {
        "hashicorp": {
          "type": ["object", "null"],
          "default": null,
          "properties": {
            "connectionString": {
              "type": ["string", "null"],
              "default": null
            }
          }
        }
      }
    },
    "podAnnotations": {
      "type": "object"
    },
    "podLabels": {
      "type": "object",
      "description": "Additional labels for agent pods"
    },
    "nodeSelector": {
      "type": "object"
    },
    "affinity": {
      "type": "object"
    },
    "tolerations": {
      "type": "array"
    },
    "global": {
      "type": "object",
      "properties": {
        "environment": {
          "type": "string",
          "default": "onprem"
        }
      }
    },
    "platform": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "default": "native",
          "description": "Cloud platform mode. Determines service account annotations and KMS integration.",
          "enum": [
            "gcp",
            "aws",
            "azure",
            "native"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "mode": { "const": "aws" } }
          },
          "then": {
            "properties": {
              "aws": {
                "type": "object",
                "required": ["iamRole"],
                "properties": {
                  "iamRole": { "type": "string", "description": "IAM role ARN for IRSA" }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "mode": { "const": "gcp" } }
          },
          "then": {
            "properties": {
              "gcp": {
                "type": "object",
                "required": ["serviceAccount", "projectId"],
                "properties": {
                  "serviceAccount": { "type": "string", "description": "GKE service account name" },
                  "projectId": { "type": "string", "description": "GCP project ID" }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "mode": { "const": "azure" } }
          },
          "then": {
            "properties": {
              "azure": {
                "type": "object",
                "required": ["clientId", "keyVaultName"],
                "properties": {
                  "clientId": { "type": "string", "description": "Azure AD application client ID" },
                  "keyVaultName": { "type": "string", "description": "Azure Key Vault name" }
                }
              }
            }
          }
        }
      ]
    },
    "agent": {
      "type": "object",
      "required": ["image", "replicas"],
      "description": "Agent configuration. Either token or secretRef.name must be provided.",
      "properties": {
        "token": {
          "type": "string",
          "default": "",
          "description": "Base64-encoded agent token blob. Leave empty if using agent.secretRef."
        },
        "secretRef": {
          "type": "object",
          "description": "Reference a pre-existing Secret containing the agent configuration.",
          "properties": {
            "name": {
              "type": "string",
              "default": "",
              "description": "Name of the existing Secret. When set, agent.token is ignored."
            },
            "key": {
              "type": "string",
              "default": "ENTITLE_JSON_CONFIGURATION",
              "description": "Key within the Secret that holds the agent configuration JSON."
            }
          }
        },
        "replicas": {
          "type": "integer",
          "minimum": 1
        },
        "resources": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            }
          }
        },
        "image": {
          "type": "object",
          "required": ["repository"],
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string", "default": "latest" }
          }
        },
        "kafka": {
          "type": "object",
          "properties": {
            "bootstrapServers": {
              "type": ["string", "null"],
              "default": null,
              "description": "Kafka public bootstrap servers (optional)"
            }
          }
        }
      }
    },
    "datadog": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the Datadog Helm subchart"
        },
        "sidecarLogs": {
          "type": "boolean",
          "default": true,
          "description": "Enable Datadog sidecar container for log shipping"
        },
        "datadog": {
          "type": "object",
          "properties": {
            "apiKey": {
              "type": ["string", "null"],
              "default": null,
              "description": "Datadog API key (required when datadog.enabled is true)"
            }
          }
        }
      }
    }
  }
}
